{
  "name": "pagepilot-kit",
  "version": "0.2.0",
  "description": "An AI-maintainable Astro static site kit with repo-local agent guardrails.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "keywords": [
    "astro",
    "static-site",
    "ai",
    "agent",
    "website-template",
    "site-kit"
  ],
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build && tsx scripts/generate-site-files.ts dist",
    "preview": "astro preview --host 127.0.0.1",
    "typecheck": "astro check",
    "test": "tsx --test tests/**/*.test.ts",
    "audit:high": "pnpm audit --prod --audit-level high",
    "pagepilot:check": "tsx scripts/pagepilot-check.ts ."
  },
  "dependencies": {
    "astro": "7.1.1",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "5.10.1",
    "gray-matter": "^4.0.3",
    "node-html-parser": "^9.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
