---
import type { Seo } from "../lib/types";
import site from "../../data/site.json";
import navigation from "../../data/navigation.json";
import theme from "../../data/theme.json";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";

const { seo, structuredData } = Astro.props as {
  seo: Seo;
  structuredData?: Record<string, unknown>;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO seo={seo} site={site} structuredData={structuredData} />
    <style is:global define:vars={{
      ink: theme.colors.ink,
      paper: theme.colors.paper,
      muted: theme.colors.muted,
      accent: theme.colors.accent,
      accentDark: theme.colors.accentDark,
      highlight: theme.colors.highlight,
      radius: `${theme.radius}px`
    }}>
      :root {
        color-scheme: light;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--paper);
        color: var(--ink);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-width: 320px;
        background: var(--paper);
      }

      body,
      input,
      textarea,
      button {
        font: inherit;
      }

      a {
        color: inherit;
        text-decoration-color: color-mix(in srgb, var(--accent), transparent 45%);
        text-underline-offset: 0.2em;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        max-width: 14ch;
        font-size: clamp(2.6rem, 7vw, 5.5rem);
        line-height: 1;
        font-weight: 750;
        letter-spacing: 0;
      }

      h2 {
        font-size: clamp(1.7rem, 3.5vw, 3rem);
        line-height: 1.05;
        letter-spacing: 0;
      }

      h3 {
        font-size: 1.05rem;
        line-height: 1.25;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      main {
        overflow: hidden;
      }

      .site-header,
      .site-footer,
      .hero-section,
      .section-band,
      .text-section,
      .cta-section,
      .contact-section,
      .article-shell,
      .not-found {
        width: min(1180px, calc(100% - 32px));
        margin-inline: auto;
      }

      .site-header {
        min-height: 76px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding-block: 18px;
      }

      .site-header img {
        width: 150px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
      }

      .desktop-nav,
      .site-footer nav,
      .site-footer address {
        display: flex;
        align-items: center;
        gap: 22px;
        font-size: 0.95rem;
        font-style: normal;
      }

      .mobile-nav {
        display: none;
      }

      .hero-section {
        display: grid;
        grid-template-columns: minmax(300px, 0.95fr) minmax(0, 1fr);
        align-items: center;
        gap: clamp(28px, 5vw, 64px);
        min-height: 680px;
        padding-block: 28px 56px;
      }

      .hero-copy {
        display: grid;
        gap: 24px;
      }

      .hero-subhead {
        max-width: 62ch;
        font-size: 1.2rem;
      }

      .eyebrow {
        color: var(--accentDark);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button,
      button {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        border-radius: var(--radius);
        padding: 0 18px;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
      }

      .button.primary,
      button {
        background: var(--ink);
        color: white;
      }

      .button.secondary {
        border-color: color-mix(in srgb, var(--ink), transparent 72%);
        background: white;
      }

      .placeholder-visual {
        display: grid;
        place-items: center;
        border: 1px solid color-mix(in srgb, var(--ink), transparent 76%);
        border-radius: var(--radius);
        background:
          linear-gradient(135deg, color-mix(in srgb, var(--ink), transparent 94%) 25%, transparent 25%) 0 0 / 28px 28px,
          linear-gradient(135deg, transparent 75%, color-mix(in srgb, var(--ink), transparent 94%) 75%) 0 0 / 28px 28px,
          #eef1f4;
        color: color-mix(in srgb, var(--ink), transparent 42%);
      }

      .placeholder-visual--hero {
        min-height: clamp(300px, 50vw, 520px);
        aspect-ratio: 1 / 1;
      }

      .placeholder-visual--card {
        width: 100%;
        aspect-ratio: 1 / 0.78;
        background-color: #9ba5b1;
        color: #d9dee5;
      }

      .placeholder-visual--small {
        min-height: 260px;
        aspect-ratio: 0.78 / 1;
      }

      .placeholder-icon {
        width: clamp(42px, 8vw, 76px);
        fill: none;
        stroke: currentColor;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .section-band,
      .text-section,
      .contact-section,
      .article-shell {
        padding-block: 76px;
      }

      .section-heading {
        display: grid;
        gap: 12px;
        margin-bottom: 28px;
        text-align: center;
        justify-items: center;
      }

      .feature-grid,
      .product-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
      }

      .feature-grid article,
      .product-card,
      .blog-list article {
        display: grid;
        gap: 12px;
        border: 1px solid color-mix(in srgb, var(--ink), transparent 86%);
        border-radius: var(--radius);
        background: white;
        padding: 18px;
      }

      .product-card {
        min-height: 320px;
        align-content: space-between;
      }

      .blog-list {
        display: grid;
        gap: 14px;
      }

      .cta-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        border-block: 1px solid color-mix(in srgb, var(--ink), transparent 86%);
        padding-block: 48px;
      }

      .cta-section div,
      .article-shell {
        display: grid;
        gap: 16px;
      }

      .text-section {
        display: grid;
        gap: 16px;
      }

      .text-section--visual {
        grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
        align-items: center;
        gap: clamp(32px, 6vw, 80px);
      }

      .text-copy {
        display: grid;
        gap: 16px;
      }

      .stacked-placeholders {
        min-height: 340px;
        position: relative;
      }

      .stacked-placeholders .placeholder-visual:first-child {
        width: 58%;
        background-color: #9ba5b1;
      }

      .stacked-placeholders .placeholder-visual:last-child {
        position: absolute;
        right: 16%;
        top: 12%;
        width: 46%;
        background-color: #eef1f4;
      }

      .contact-section {
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(280px, 0.7fr);
        gap: 40px;
      }

      form {
        display: grid;
        gap: 10px;
        border: 1px solid color-mix(in srgb, var(--ink), transparent 86%);
        border-radius: var(--radius);
        background: white;
        padding: 22px;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid color-mix(in srgb, var(--ink), transparent 78%);
        border-radius: var(--radius);
        padding: 12px;
      }

      .site-footer {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 32px;
        border-top: 1px solid color-mix(in srgb, var(--ink), transparent 86%);
        padding-block: 34px;
      }

      .not-found {
        display: grid;
        gap: 18px;
        min-height: 58vh;
        align-content: center;
      }

      [data-pp-edit-id] {
        scroll-margin: 96px;
      }

      @media (max-width: 820px) {
        .desktop-nav {
          display: none;
        }

        .mobile-nav {
          display: block;
          position: relative;
        }

        .mobile-nav summary {
          min-height: 42px;
          display: inline-flex;
          align-items: center;
          border: 1px solid color-mix(in srgb, var(--ink), transparent 74%);
          border-radius: var(--radius);
          padding: 0 14px;
          cursor: pointer;
        }

        .mobile-nav nav {
          position: absolute;
          right: 0;
          top: calc(100% + 8px);
          z-index: 10;
          min-width: 190px;
          display: grid;
          gap: 10px;
          border: 1px solid color-mix(in srgb, var(--ink), transparent 78%);
          border-radius: var(--radius);
          background: white;
          padding: 14px;
          box-shadow: 0 18px 46px color-mix(in srgb, var(--ink), transparent 86%);
        }

        .hero-section,
        .text-section--visual,
        .contact-section,
        .site-footer {
          grid-template-columns: 1fr;
        }

        .hero-section {
          min-height: auto;
          padding-block: 36px 64px;
        }

        .feature-grid,
        .product-grid {
          grid-template-columns: 1fr;
        }

        .placeholder-visual--hero {
          min-height: 280px;
          aspect-ratio: 1.15 / 1;
        }

        .stacked-placeholders {
          min-height: 300px;
        }

        .cta-section {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <Header site={site} navigation={navigation.header} />
    <main>
      <slot />
    </main>
    <Footer site={site} navigation={navigation.footer} />
  </body>
</html>
