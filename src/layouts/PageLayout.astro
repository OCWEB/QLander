---
import type { PageContent, Product } from "../lib/types";
import { getCollection } from "astro:content";
import { site } from "../lib/site";
import ContactForm from "../components/ContactForm.astro";
import CTASection from "../components/CTASection.astro";
import FaqSection from "../components/FaqSection.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import HeroSection from "../components/HeroSection.astro";
import LocationsSection from "../components/LocationsSection.astro";
import LogoStrip from "../components/LogoStrip.astro";
import ProductGrid from "../components/ProductGrid.astro";
import RichTextSection from "../components/RichTextSection.astro";
import ScrollSection from "../components/ScrollSection.astro";
import StatsSection from "../components/StatsSection.astro";
import StepsSection from "../components/StepsSection.astro";
import TestimonialSection from "../components/TestimonialSection.astro";
import { ScrollWorldExperienceSchema } from "../lib/schemas";
import { pageHandoffs, sectionHandoffs } from "../layout-handoffs";
import BaseLayout from "./BaseLayout.astro";

const { page, showHeroVisual = true, products: suppliedProducts } = Astro.props as {
  page: PageContent;
  showHeroVisual?: boolean;
  products?: Product[];
};
const pageRoute = page.slug === "home" ? "/" : `/${page.slug}`;
const PageHandoff = pageHandoffs[pageRoute];
const needsProducts = page.sections.some((section) => section.type === "productGrid" || Boolean(sectionHandoffs[section.id])) || Boolean(PageHandoff);
const products = suppliedProducts ?? (needsProducts ? (await getCollection("products")).map((entry) => entry.data as Product) : []);
const experienceModules = import.meta.glob<{ default: unknown }>("../../data/experiences/*.json", { eager: true });
const sectionExperiences = new Map(Object.values(experienceModules)
  .map((module) => ScrollWorldExperienceSchema.parse(module.default))
  .filter((experience) => experience.placement === "section")
  .map((experience) => [experience.slug, experience]));
const sectionExperience = (slug: string) => {
  const experience = sectionExperiences.get(slug);
  if (!experience) throw new Error(`Missing section Scroll World experience ${slug}`);
  return experience;
};
---

<BaseLayout seo={page.seo} chrome={page.layout === "ppc" ? "landing" : "site"}>
  {PageHandoff ? <PageHandoff page={page} products={products} /> : page.sections.map((section, index) => {
    const SectionHandoff = sectionHandoffs[section.id];
    return SectionHandoff ? <SectionHandoff section={section} page={page} products={products} /> :
      section.type === "hero" ? <HeroSection section={section} showVisual={showHeroVisual && index === 0} /> :
      section.type === "featureGrid" ? <FeatureGrid section={section} /> :
      section.type === "cta" ? <CTASection section={section} /> :
      section.type === "productGrid" ? <ProductGrid products={products.filter((product) => section.productSlugs.includes(product.slug))} headline={section.headline} headingLevel="h2" editId={section.id} /> :
      section.type === "contact" ? <ContactForm section={section} site={site} /> :
      section.type === "richText" ? <RichTextSection section={section} /> :
      section.type === "stats" ? <StatsSection section={section} /> :
      section.type === "faq" ? <FaqSection section={section} /> :
      section.type === "testimonial" ? <TestimonialSection section={section} /> :
      section.type === "logoStrip" ? <LogoStrip section={section} /> :
      section.type === "steps" ? <StepsSection section={section} /> :
      section.type === "locations" ? <LocationsSection section={section} /> :
      section.type === "scrollSection" ? <ScrollSection experience={sectionExperience(section.experience)} sectionId={section.id} headingLevel={section.headingLevel} /> :
      null;
  })}
</BaseLayout>
