---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../lib/site";
import { blogPostingSchema } from "../../lib/structuredData";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => post.data.routed);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout seo={post.data.seo} structuredData={blogPostingSchema(site, post.data)} ogType="article">
  <article class="article-shell">
    <p class="eyebrow"><time datetime={post.data.publishedAt}>{post.data.publishedAt}</time> · {post.data.author}</p>
    <h1>{post.data.title}</h1>
    <p>{post.data.description}</p>
    <Content />
  </article>
</BaseLayout>
