---
import BlogList from "../../components/BlogList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const modules = import.meta.glob("../../../content/blog/*.md", { eager: true });
const posts = Object.values(modules).map((post: any) => post.frontmatter).sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));
const seo = {
  title: "Blog | PagePilot Starter",
  description: "Placeholder posts for the PagePilot Starter site.",
  noindex: false,
  canonical: "https://example.com/blog"
};
---

<BaseLayout seo={seo}>
  <BlogList posts={posts} />
</BaseLayout>
