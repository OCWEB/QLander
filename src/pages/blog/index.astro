---
import BlogList from "../../components/BlogList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import routeSeo from "../../../data/route-seo.json";

const posts = (await getCollection("blog")).map((entry) => entry.data).sort((a, b) => b.publishedAt.localeCompare(a.publishedAt));
---

<BaseLayout seo={routeSeo.blog}>
  <BlogList posts={posts} eyebrow={routeSeo.blog.eyebrow} heading={routeSeo.blog.heading} />
</BaseLayout>
