---
import type { Product } from "../../lib/types";
import { getCollection } from "astro:content";
import { site } from "../../lib/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { productSchema } from "../../lib/structuredData";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { product: entry.data as Product }
  }));
}

const { product } = Astro.props as { product: Product };
---

<BaseLayout seo={product.seo} structuredData={productSchema(site, product)}>
  <article class="article-shell">
    <p class="eyebrow">{product.priceLabel}</p>
    <h1>{product.title}</h1>
    <p>{product.summary}</p>
    <p>{product.description}</p>
    {product.image && <img class="content-image" src={product.image.src} alt={product.image.alt} width={product.image.width} height={product.image.height} />}
    <a class="button primary" href="/contact">Ask about this offer</a>
  </article>
</BaseLayout>
