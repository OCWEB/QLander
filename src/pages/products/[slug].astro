---
import type { Product } from "../../lib/types";
import site from "../../../data/site.json";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { productSchema } from "../../lib/structuredData";

export function getStaticPaths() {
  const modules = import.meta.glob("../../../content/products/*.json", { eager: true, import: "default" });
  const products = Object.values(modules) as Product[];
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props as { product: Product };
---

<BaseLayout seo={product.seo} structuredData={productSchema(site, product)}>
  <article class="article-shell">
    <p class="eyebrow">{product.priceLabel}</p>
    <h1>{product.title}</h1>
    <p>{product.summary}</p>
    <p>{product.description}</p>
    <a class="button primary" href="/contact">Ask about this offer</a>
  </article>
</BaseLayout>
