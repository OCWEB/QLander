---
import type { Product } from "../../lib/types";
import { getCollection } from "astro:content";
import routeSeo from "../../../data/route-seo.json";
import ProductGrid from "../../components/ProductGrid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const products = (await getCollection("products")).map((entry) => entry.data as Product);
---

<BaseLayout seo={routeSeo.products}>
  <ProductGrid products={products} headline="Starter offers" headingLevel="h1" />
</BaseLayout>
