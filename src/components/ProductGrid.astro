---
import type { Product } from "../lib/types";
import PlaceholderVisual from "./PlaceholderVisual.astro";

const { products, headline = "Products", eyebrow = "Products", itemCtaLabel = "View product", headingLevel = "h2", editId } = Astro.props as {
  products: Product[];
  headline?: string;
  eyebrow?: string;
  itemCtaLabel?: string;
  headingLevel?: "h1" | "h2";
  editId?: string;
};
const Heading = headingLevel;
---

<section class="section-band" data-pp-edit-id={editId}>
  <div class="section-heading">
    <p class="eyebrow">{eyebrow}</p>
    <Heading>{headline}</Heading>
  </div>
  <div class="product-grid">
    {products.map((product) => (
      <article class="product-card">
        {product.image ? <img class="content-image" src={product.image.src} alt={product.image.alt} width={product.image.width} height={product.image.height} loading="lazy" decoding="async" /> : <PlaceholderVisual label={`${product.title} image placeholder`} promptId={product.imagePromptId} variant="card" />}
        <div>
          {product.priceLabel && <p class="eyebrow">{product.priceLabel}</p>}
          <h2>{product.title}</h2>
          <p>{product.summary}</p>
        </div>
        <a class="button secondary" href={`/products/${product.slug}`}>{product.ctaLabel ?? itemCtaLabel}</a>
      </article>
    ))}
  </div>
</section>
