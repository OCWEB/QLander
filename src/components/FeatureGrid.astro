---
import type { PageSection } from "../lib/types";
import PlaceholderVisual from "./PlaceholderVisual.astro";

type FeatureGridSection = Extract<PageSection, { type: "featureGrid" }>;

const { section } = Astro.props as {
  section: FeatureGridSection;
};
---

<section class="section-band" data-pp-edit-id={section.id}>
  <div class="section-heading">
    {section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
    <h2>{section.headline}</h2>
  </div>
  <div class="feature-grid">
    {section.items.map((item) => (
      <article>
        {item.image ? <img class="content-image" src={item.image.src} alt={item.image.alt} width={item.image.width} height={item.image.height} loading="lazy" decoding="async" /> : <PlaceholderVisual label={`${item.title} image placeholder`} promptId={item.imagePromptId} variant="card" />}
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>
