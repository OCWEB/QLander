---
import type { ScrollWorldExperience } from "../lib/types";
import { serializeJsonLd } from "../lib/schemas";
import { site } from "../lib/site";
import designSystem from "../../data/design-system.json";
import theme from "../../data/theme.json";
import manifest from "../../qlander.manifest.json";
import SEO from "./SEO.astro";
import scrubEngine from "../../skills/scroll-world/references/scrub-engine.js?raw";

const { experience, editId } = Astro.props as { experience: ScrollWorldExperience; editId: string };
const serialized = serializeJsonLd(experience);
---

<!doctype html>
<html lang={site.locale} data-surface={designSystem.components.surface} data-image-treatment={designSystem.components.image} data-motion={designSystem.motion}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="qlander-site-id" content={manifest.siteId} />
    <SEO seo={experience.seo} site={site} />
    <style define:vars={{
      ink: theme.colors.ink,
      paper: theme.colors.paper,
      muted: theme.colors.muted,
      accent: theme.colors.accent,
      radius: `${theme.radius}px`,
      fontDisplay: designSystem.typography.displayFamily,
      fontBody: designSystem.typography.bodyFamily,
      displayWeight: designSystem.typography.displayWeight,
      bodyWeight: designSystem.typography.bodyWeight,
      bodyLeading: designSystem.typography.bodyLeading,
      headingMin: `${designSystem.typography.headingMinRem}rem`,
      headingMax: `${designSystem.typography.headingMaxRem}rem`,
      bodySize: `${designSystem.typography.bodyRem}rem`,
      sectionY: `${designSystem.spacing.sectionY}px`,
      readingMax: `${designSystem.layout.readingMax}ch`
    }}>
      :root, .sw-root {
        --sw-bg: var(--paper);
        --sw-ink: var(--ink);
        --sw-ink-soft: var(--muted);
        --sw-accent: var(--accent);
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; overflow-x: hidden; background: var(--paper); color: var(--ink); font-family: var(--fontBody); font-size: var(--bodySize); font-weight: var(--bodyWeight); }
      #world { min-height: 100vh; }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
      .sw-fallback { width: min(920px, calc(100% - 32px)); margin: 0 auto; padding: var(--sectionY) 0; }
      .sw-fallback__brand { display: inline-block; margin-bottom: 48px; color: inherit; }
      .sw-fallback article { padding: 40px 0; border-top: 1px solid color-mix(in srgb, var(--ink), transparent 80%); }
      .sw-fallback img { width: 100%; height: auto; margin-bottom: 28px; border-radius: var(--radius); }
      .sw-fallback h2 { margin: 8px 0 12px; font-family: var(--fontDisplay); font-size: clamp(var(--headingMin), 6vw, var(--headingMax)); font-weight: var(--displayWeight); }
      .sw-fallback p { max-width: var(--readingMax); color: var(--muted); line-height: var(--bodyLeading); }
      .sw-fallback a { color: inherit; }
      .sw-mounted .sw-fallback { display: none; }
    </style>
  </head>
  <body>
    <h1 class="sr-only">{experience.seo.title}</h1>
    <main id="world" data-pp-edit-id={editId}>
      <div class="sw-fallback">
        <a class="sw-fallback__brand" href={experience.brand.href}>← {experience.brand.name}</a>
        {experience.sections.map((section) => (
          <article>
            <img src={section.stillMobile ?? section.still} alt="" width="1600" height="900" />
            {section.eyebrow && <small>{section.eyebrow}</small>}
            <h2>{section.title}</h2>
            <p>{section.body}</p>
            {section.cta && <p><a href={section.cta.primary.href}>{section.cta.primary.label}</a></p>}
          </article>
        ))}
      </div>
    </main>
    <script is:inline set:html={scrubEngine} />
    <script is:inline set:html={`mountScrollWorld(document.getElementById("world"), ${serialized}); document.documentElement.classList.add("sw-mounted");`} />
  </body>
</html>
