---
import type { SiteData } from "../lib/types";

const { headline, body, site, editId } = Astro.props as {
  headline: string;
  body: string;
  site: SiteData;
  editId?: string;
};
const action = site.contactUrl || (site.email ? `mailto:${site.email}` : undefined);
---

<section class="contact-section" data-pp-edit-id={editId}>
  <div>
    <p class="eyebrow">Contact</p>
    <h2>{headline}</h2>
    <p>{body}</p>
    {site.email && <a href={`mailto:${site.email}`}>{site.email}</a>}
    {site.phone && <a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>}
  </div>
  <div class="contact-action">
    <p>{site.contactUrl ? "Continue to the approved contact destination." : site.email ? "Email is the available contact path." : "Contact details will be added before launch."}</p>
    {action && <a class="button primary" href={action}>Contact {site.name}</a>}
  </div>
</section>
