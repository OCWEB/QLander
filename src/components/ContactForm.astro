---
import type { PageSection, SiteData } from "../lib/types";

type ContactSection = Extract<PageSection, { type: "contact" }>;
const { section, site } = Astro.props as {
  section: ContactSection;
  site: SiteData;
};
const action = site.contactUrl || (site.email ? `mailto:${site.email}` : undefined);
---

<section class="contact-section" data-pp-edit-id={section.id}>
  <div>
    <p class="eyebrow">{section.eyebrow ?? "Contact"}</p>
    <h2>{section.headline}</h2>
    <p>{section.body}</p>
    {section.mode === "action" && site.email && <a href={`mailto:${site.email}`}>{site.email}</a>}
    {section.mode === "action" && site.phone && <a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>}
    {section.channels && section.channels.length > 0 && (
      <ul class="contact-channels">
        {section.channels.map((channel) => (
          <li>
            <strong>{channel.label}</strong>
            {channel.phone && <a href={`tel:${channel.phone.replaceAll(" ", "")}`}>{channel.phone}</a>}
            {channel.email && <a href={`mailto:${channel.email}`}>{channel.email}</a>}
            {channel.hoursNote && <span>{channel.hoursNote}</span>}
          </li>
        ))}
      </ul>
    )}
  </div>
  {section.mode === "informational" ? (
    section.informationalNote && <div class="contact-action"><p>{section.informationalNote}</p></div>
  ) : (
    <div class="contact-action">
      <p>{site.contactUrl ? "Continue to the approved contact destination." : site.email ? "Email is the available contact path." : "Contact details will be added before launch."}</p>
      {action && <a class="button primary" href={action}>{section.actionLabel ?? `Contact ${site.name}`}</a>}
    </div>
  )}
</section>
