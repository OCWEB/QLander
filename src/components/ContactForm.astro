---
import type { SiteData } from "../lib/types";

const { headline, body, site, editId } = Astro.props as {
  headline: string;
  body: string;
  site: SiteData;
  editId?: string;
};
---

<section class="contact-section" data-pp-edit-id={editId}>
  <div>
    <p class="eyebrow">Contact</p>
    <h2>{headline}</h2>
    <p>{body}</p>
    <a href={`mailto:${site.email}`}>{site.email}</a>
  </div>
  <div class="contact-action">
    <p>Email is the reliable contact path for this starter until a form provider is explicitly configured.</p>
    <a class="button primary" href={`mailto:${site.email}`}>Email {site.name}</a>
  </div>
</section>
